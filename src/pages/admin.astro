<!doctype html>
<html>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="robots" content="noindex" />
        <link href="/admin/config.yml" type="text/yaml" rel="cms-config-url" />
        <title>Edit</title>
        <style is:inline>
            /* Hide secondary + editor toolbars on mobile by default */
            @media (max-width: 768px) {

                #first-pane-header .sui.toolbar.secondary,
                .sui.text-editor .sui.toolbar {
                    max-height: 0;
                    overflow: hidden;
                    transition: max-height 0.2s ease;
                }

                body.toolbars-visible #first-pane-header .sui.toolbar.secondary,
                body.toolbars-visible .sui.text-editor .sui.toolbar {
                    max-height: 60px;
                }

                .toolbar-toggle {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: none;
                    border: none;
                    cursor: pointer;
                    padding: 4px;
                    margin-left: 4px;
                    border-radius: 4px;
                    color: inherit;
                    font-size: 20px;
                    line-height: 1;
                    font-family: 'Material Symbols Outlined';
                }

                .toolbar-toggle:hover {
                    background: rgba(128, 128, 128, 0.2);
                }
            }

            /* Make text editor toolbar scroll horizontally instead of wrapping */
            .sui.text-editor .sui.toolbar,
            .sui.text-editor .sui.toolbar .inner {
                flex-wrap: nowrap !important;
                overflow-x: auto !important;
                overflow-y: hidden !important;
                -webkit-overflow-scrolling: touch;
            }

            .sui.text-editor .sui.toolbar,
            .sui.text-editor .sui.toolbar .inner {
                scrollbar-width: none;
            }

            .sui.text-editor .sui.toolbar::-webkit-scrollbar,
            .sui.text-editor .sui.toolbar .inner::-webkit-scrollbar {
                display: none;
            }

            .sui.text-editor .sui.toolbar .inner>* {
                flex-shrink: 0;
            }

            @media (min-width: 769px) {
                .toolbar-toggle {
                    display: none;
                }
            }
        </style>
    </head>
    <body>
        <script src="https://unpkg.com/@sveltia/cms/dist/sveltia-cms.js" type="module" is:inline></script>
        <script is:inline>
            // Wait for Sveltia CMS to render, then inject toggle button
            const observer = new MutationObserver(() => {
                const primaryToolbar = document.querySelector(
                    '.content-editor .sui.toolbar.primary .inner'
                );
                if (primaryToolbar && !document.querySelector('.toolbar-toggle')) {
                    const btn = document.createElement('button');
                    btn.className = 'toolbar-toggle';
                    btn.setAttribute('aria-label', 'Toggle editor toolbars');
                    btn.textContent = 'tune';
                    btn.addEventListener('click', () => {
                        document.body.classList.toggle('toolbars-visible');
                    });
                    const saveBtn = primaryToolbar.querySelector('[data-label="Save"]');
                    if (saveBtn) {
                        primaryToolbar.insertBefore(btn, saveBtn);
                    } else {
                        primaryToolbar.appendChild(btn);
                    }
                }
            });

            observer.observe(document.body, { childList: true, subtree: true });
        </script>
    </body>
</html>
