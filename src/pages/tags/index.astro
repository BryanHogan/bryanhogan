---
import Hero from "../../components/Hero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
const tagCounts: Record<string, number> = {};
allPosts.forEach(post => {
    if (post.data.tags) {
        post.data.tags.forEach(tag => {
            tagCounts[tag] = (tagCounts[tag] || 0) + 1;
        });
    }
});
---

<BaseLayout
    title="Blog Topics - Bryan Hogan"
    description="Browse all topics and tags covered on Bryan Hogan's blog, such as development, Korea, productivity and more."
>
    <Hero overline="Topics" heading="Browse all blog posts by topic." />
    <h2 class="text-align-center margin-top-xl margin-bottom-m">All Tags</h2>
    <ul class="margin-bottom-l">
        {
            tags.map((tag) => (
                <li>
                    <a href={`/tags/${tag}`} class="tag-name">{tag}</a> ({tagCounts[tag] || 0})
                </li>
            ))
        }
      </ul>
</BaseLayout>

<style>
    ul {
        margin-inline: auto;
    }
    .tag-name {
        text-transform: capitalize;
    }
</style>