---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import CardBlog from "../../components/CardBlog.astro";
import { cardBlogBackgroundColors } from "../../data/colors";
import tagData from "../../data/tags";

export async function getStaticPaths() {
    const allPosts = await getCollection("blog");
    const uniqueTags = [
        ...new Set(allPosts.map((post) => post.data.tags).flat()),
    ];

    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts
            .filter((post) => post.data.tags.includes(tag))
            .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}
const { tag } = Astro.params;
const { posts } = Astro.props;

const data = tagData[tag];
const capitalizedTag = tag.charAt(0).toUpperCase() + tag.slice(1);
const heroH1 = data?.heroTitle ?? capitalizedTag;
const heroSubtitle = data?.heroSubtitle ?? ("Bryan's blog on " + tag + ".");
const seoTitle = "Tag: " + capitalizedTag + " - Bryan's Blog";
const seoDescription = data?.seoDescription
    ?? ("Articles about " + capitalizedTag + " - guides, insights, and lessons learned by Bryan Hogan.");
---

<BaseLayout
    title={seoTitle}
    description={seoDescription}
>
    <Hero h1={heroH1} subtitle={heroSubtitle} />
    {data?.explanation && (
        <p class="margin-top-l set-main-content-max-width margin-inline-auto">{data.explanation}</p>
    )}
    <h2 class="text-align-center margin-top-xl margin-bottom-l">{"Posts about " + capitalizedTag}</h2>
    <ul role="list" class="blog-posts-container margin-bottom-xl">
    {
        posts.map((post, index) => (
            <li>
                <CardBlog post={post} backgroundColor={cardBlogBackgroundColors[index % cardBlogBackgroundColors.length]} transitionIcon/>
            </li>
        ))
    }
    </ul>
</BaseLayout>

<style>
.blog-posts-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-l);
    }
    @media (min-width: 32rem) {
        .blog-posts-container {
            grid-template-columns: 1fr 1fr;
        }
    }
    @media (min-width: 74rem) {
        .blog-posts-container {
            grid-template-columns: 1fr 1fr 1fr 1fr;
        }
    }
</style>
