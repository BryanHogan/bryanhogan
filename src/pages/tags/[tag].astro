---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import CardBlog from "../../components/CardBlog.astro";
import { cardBlogBackgroundColors } from "../../data/colors";
import tagData from "../../data/tags";

export async function getStaticPaths() {
    const allPosts = await getCollection("blog");
    const uniqueTags = [
        ...new Set(allPosts.map((post) => post.data.tags).flat()),
    ];

    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts
            .filter((post) => post.data.tags.includes(tag))
            .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}
const { tag } = Astro.params;
const { posts } = Astro.props;

const data = tagData[tag];
const capitalizedTag = tag.charAt(0).toUpperCase() + tag.slice(1);
const heroOverline = data?.title ?? capitalizedTag;
const heroHeading = "Bryan's blog about " + capitalizedTag + ".";
const seoTitle = "Tag: " + capitalizedTag + " - Bryan's Blog";
const seoDescription = data?.description
    ? "Bryan's blog about " + (data.title ?? capitalizedTag) + ". " + data.description
    : "Posts about " + capitalizedTag + " - guides, insights, and lessons learned by Bryan Hogan.";
---

<BaseLayout
    title={seoTitle}
    description={seoDescription}
>
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Blog", "item": "https://bryanhogan.com/blog" },
            { "@type": "ListItem", "position": 2, "name": "Tags", "item": "https://bryanhogan.com/tags" },
            { "@type": "ListItem", "position": 3, "name": capitalizedTag, "item": "https://bryanhogan.com/tags/" + tag }
        ]
    })} />
    <Hero overline={heroOverline} heading={heroHeading} />
    <main>
        <nav class="sub-nav-container">
            <ul role="list">
                <li><a href="/blog">Blog</a></li>
                <li><a href="/tags">Tags</a></li>
                <li><span>{capitalizedTag}</span></li>
            </ul>
        </nav>
        {data?.description && (
            <p class="margin-top-m set-main-content-max-width margin-inline-auto">{data.description}</p>
        )}
        <section aria-labelledby="posts-heading">
            <h2 id="posts-heading" class={`text-align-center margin-bottom-l ${data?.description ? "margin-top-xl" : "margin-top-m"}`}>{"Posts about " + capitalizedTag}</h2>
            <ul role="list" class="blog-posts-container margin-bottom-xl">
            {
                posts.map((post, index) => (
                    <li>
                        <CardBlog post={post} backgroundColor={cardBlogBackgroundColors[index % cardBlogBackgroundColors.length]} transitionIcon/>
                    </li>
                ))
            }
            </ul>
        </section>
    </main>
</BaseLayout>

<style>
    .sub-nav-container ul {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-start;
        gap: var(--space-xs) var(--space-s);
        padding-block: var(--space-xs);
        li a, li span {
            color: var(--color-neutral-300);
            text-decoration: none;
            font-size: 0.75em;
            &:hover {
                color: var(--a-hover-color);
            }
        }
        li:not(:first-child)::before {
            content: "/";
            color: var(--color-neutral-500);
            font-size: 0.75em;
            padding-right: var(--space-s);
        }
    }
    .blog-posts-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-l);
    }
    @media (min-width: 32rem) {
        .blog-posts-container {
            grid-template-columns: 1fr 1fr;
        }
    }
    @media (min-width: 74rem) {
        .blog-posts-container {
            grid-template-columns: 1fr 1fr 1fr 1fr;
        }
    }
</style>
