---
/* Header.astro */

:root {
  --header-backdrop: hsl(0 0 0 / 0.7);
}

.header-container {
  position: relative;
}

.header-container::after {
  content: '';
  position: fixed;
  inset: 0;
  background: var(--header-backdrop);
  z-index: 1;
}

/* Other existing styles */

nav {
  z-index: 2; /* Ensure nav is above the backdrop */
}

