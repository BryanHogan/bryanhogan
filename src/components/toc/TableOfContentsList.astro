---
import type { TocItem } from "./generateToC";

interface Props {
	toc: TocItem[];
	depth?: number;
}

const { toc, depth = 0 } = Astro.props;
---

<ul>
	{
		toc.map((heading) => (
			<li>
				<a href={"#" + heading.slug}>
					<span>{heading.text}</span>
				</a>
				{heading.children.length > 0 && (
					<Astro.self toc={heading.children} depth={depth + 1} />
				)}
			</li>
		))
	}
</ul>

<style define:vars={{ depth }}>
	ul {
		padding: 0;
		list-style: none;
	}
	a {
		--pad-inline: 0.5rem;
		display: block;
		border-radius: 0.25rem;
		padding-block: 0.15rem;
		padding-inline: calc(1rem * var(--depth) + var(--pad-inline))
			var(--pad-inline);
		line-height: 1.25;
		color: var(--color-neutral-400);
		text-decoration: none;
		font-size: var(--font-size-small);
		&:hover {
			color: var(--color-accent-500);
		}
	}
	.active {
		color: var(--color-neutral-200);
		text-shadow: var(--text-shadow-m);
	}
</style>

<script>
	const isInViewport = (elem: Element) => {
		const bounding = elem.getBoundingClientRect();
		return bounding.bottom >= 0 && bounding.top <= window.innerHeight * 0.8;
	};

	const handleScroll = () => {
		// #_top is the post title, rendered outside .main-content
		const headings = document.querySelectorAll(
			"#_top, .main-content :is(h1, h2, h3, h4, h5, h6)",
		);
		let activeHeading: Element | null = null;

		for (const heading of headings) {
			if (isInViewport(heading)) activeHeading = heading;
		}
		if (!activeHeading) return;

		const activeLink = document.querySelector(
			`.toc a[href="#${activeHeading.id}"]`,
		);
		if (!activeLink) return;

		document.querySelectorAll(".toc a").forEach((link) => {
			link.classList.remove("active");
			link.removeAttribute("aria-current");
		});
		activeLink.classList.add("active");
		activeLink.setAttribute("aria-current", "true");
	};

	// With the ClientRouter this script re-executes whenever navigation enters a
	// blog page from a page that doesn't include it, so guard the registration.
	const w = window as Window & { tocHighlightInit?: boolean };
	if (!w.tocHighlightInit) {
		w.tocHighlightInit = true;
		window.addEventListener("scroll", handleScroll);
		// Fires on initial load and after every view-transition navigation,
		// so the highlight is correct before the user scrolls.
		document.addEventListener("astro:page-load", handleScroll);
	}
</script>


